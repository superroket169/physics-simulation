
    // ----------- HELPERS ------------
    
    inline float calculateAngularEffect(PhysicsBody* body, Vector3 r, Vector3 axis) {
        if (body->getState().inverseMass == 0.0f) return 0.0f;
        
        Vector3 rCrossAxis = Vector3CrossProduct(r, axis);
        Quaternion invOrientation = QuaternionInvert(body->getState().orientation);
        Vector3 rCrossAxis_local = Vector3RotateByQuaternion(rCrossAxis, invOrientation);
        
        Vector3 invI_cross_local = { 
            rCrossAxis_local.x * body->getState().inverseInertia.x, 
            rCrossAxis_local.y * body->getState().inverseInertia.y, 
            rCrossAxis_local.z * body->getState().inverseInertia.z 
        };
        
        Vector3 invI_cross = Vector3RotateByQuaternion(invI_cross_local, body->getState().orientation);
        Vector3 cross_invI_cross_r = Vector3CrossProduct(invI_cross, r);
        
        return Vector3DotProduct(cross_invI_cross_r, axis);
    }

    inline CollisionManifold checkSphereSphere(const PhysicsState& stateA,
                                               float radiusA,
                                               const PhysicsState& stateB,
                                               float radiusB,
                                               const PhysicsSettings& settings
                                               ) {
        CollisionManifold manifold;
        Vector3 delta = Vector3Subtract(stateB.position, stateA.position);
        float distSq = Vector3LengthSqr(delta);
        float sumRadii = radiusA + radiusB;
        
        if (distSq >= (sumRadii * sumRadii)) return manifold; 

        float distance = sqrtf(distSq);
        manifold.isColliding = true;

        if (distance <= settings.distanceEpsilon) {
            manifold.normal = { 0.0f, 1.0f, 0.0f };
            manifold.depth = sumRadii;
            manifold.contactPoint = stateA.position;
        }
        else {
            manifold.normal = Vector3Scale(delta, 1.0f / distance);
            manifold.depth = sumRadii - distance;
            manifold.contactPoint = Vector3Add(stateA.position, Vector3Scale(manifold.normal, radiusA - (manifold.depth * 0.5f)));
        }
        return manifold;
    }

    inline float resolveNormalCollision(PhysicsBody* a,
                                        PhysicsBody* b,
                                        Vector3 rA,
                                        Vector3 rB,
                                        Vector3 normal,
                                        float velAlongNormal
                                        ) {
        float angularEffectA = calculateAngularEffect(a, rA, normal);
        float angularEffectB = calculateAngularEffect(b, rB, normal);
        float totalInvMass = a->getState().inverseMass + b->getState().inverseMass;
        float e = std::min(a->getRestitution(), b->getRestitution());
        float j = -(1.0f + e) * velAlongNormal;
        
        j /= (totalInvMass + angularEffectA + angularEffectB);
        Vector3 impulse = Vector3Scale(normal, j);
        
        a->applyImpulseAtPoint(Vector3Scale(impulse, -1.0f), Vector3Add(a->getPosition(), rA));
        b->applyImpulseAtPoint(impulse, Vector3Add(b->getPosition(), rB));
        return j;
    }

    inline void resolveTangentCollision(PhysicsBody* a,
                                        PhysicsBody* b,
                                        Vector3 rA,
                                        Vector3 rB,
                                        Vector3 normal,
                                        Vector3 relVel,
                                        float normalImpulseMag,
                                        const PhysicsSettings& settings
                                        ) {
        float velAlongNormal = Vector3DotProduct(relVel, normal);
        Vector3 normalVelocity = Vector3Scale(normal, velAlongNormal);
        Vector3 tangentVelocity = Vector3Subtract(relVel, normalVelocity);
        float tangentSpeed = Vector3Length(tangentVelocity);
        
        if (tangentSpeed < settings.velocityEpsilon) return;

        Vector3 t = Vector3Scale(tangentVelocity, 1.0f / tangentSpeed);
        float angularEffectA = calculateAngularEffect(a, rA, t);
        float angularEffectB = calculateAngularEffect(b, rB, t);
        float totalInvMass = a->getState().inverseMass + b->getState().inverseMass;
        float jt = -tangentSpeed / (totalInvMass + angularEffectA + angularEffectB);

        Vector3 frictionImpulse;
        if (abs(jt) < normalImpulseMag * settings.baseFrictionMu) frictionImpulse = Vector3Scale(t, jt);
        else frictionImpulse = Vector3Scale(t, -normalImpulseMag * settings.baseFrictionMu);
        
        a->applyImpulseAtPoint(Vector3Scale(frictionImpulse, -1.0f), Vector3Add(a->getPosition(), rA));
        b->applyImpulseAtPoint(frictionImpulse, Vector3Add(b->getPosition(), rB));
    }

    inline void resolveCollision(PhysicsBody* a,
                                 PhysicsBody* b,
                                 const CollisionManifold& m,
                                 const PhysicsSettings& settings
                                 ) {
        Vector3 rA = Vector3Subtract(m.contactPoint, a->getPosition());
        Vector3 rB = Vector3Subtract(m.contactPoint, b->getPosition());
        Vector3 vA = a->getVelocityAtPoint(m.contactPoint);
        Vector3 vB = b->getVelocityAtPoint(m.contactPoint);
        Vector3 relVel = Vector3Subtract(vB, vA);

        float velAlongNormal = Vector3DotProduct(relVel, m.normal);
        if (velAlongNormal > 0) return; 

        float normalImpulseMag = resolveNormalCollision(a, b, rA, rB, m.normal, velAlongNormal);

        Vector3 newVA = a->getVelocityAtPoint(m.contactPoint);
        Vector3 newVB = b->getVelocityAtPoint(m.contactPoint);
        Vector3 newRelVel = Vector3Subtract(newVB, newVA);

        resolveTangentCollision(a, b, rA, rB, m.normal, newRelVel, normalImpulseMag, settings);
    }

    inline void applyPositionalCorrection(PhysicsBody* a,
                                          PhysicsBody* b,
                                          const CollisionManifold& m,
                                          const PhysicsSettings& settings
                                          ) {
        float totalInvMass = a->getState().inverseMass + b->getState().inverseMass;
        if (totalInvMass <= 0.0f) return;
        
        float correctionMag = std::max(m.depth - settings.baumgarteSlop, 0.0f) / totalInvMass * settings.baumgartePercent;
        Vector3 correction = Vector3Scale(m.normal, correctionMag);
        
        a->translate(Vector3Scale(correction, -a->getState().inverseMass)); 
        b->translate(Vector3Scale(correction,  b->getState().inverseMass));
    }

